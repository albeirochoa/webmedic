---
import BaseLayout from "../layouts/BaseLayout.astro";
import ServiceCard from "../components/ui/ServiceCard.astro";
import Button from "../components/ui/Button.astro";
import { services } from "../data/services";
---

<BaseLayout
  title="Servicios"
  description="Conoce nuestros servicios de marketing digital especializados para el sector salud: marketing digital, diseño web y SEO para médicos y clínicas."
>
  <!-- Page Header -->
  <section class="bg-gradient-to-br from-primary-950 to-primary-800 py-20 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
        Nuestros Servicios
      </h1>
      <p class="text-lg text-primary-200 max-w-2xl mx-auto leading-relaxed">
        Soluciones de marketing digital diseñadas específicamente para profesionales y organizaciones de salud.
      </p>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-20 sm:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          services.map((service) => (
            <ServiceCard
              title={service.title}
              description={service.description}
              icon={service.icon}
              features={service.features}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-4">
        ¿Necesitas una solución personalizada?
      </h2>
      <p class="text-gray-600 mb-8 max-w-xl mx-auto">
        Cada práctica médica es única. Contáctanos para diseñar una estrategia a tu medida.
      </p>
      <Button href="/#contacto" variant="primary" size="lg">
        Hablar con un especialista
      </Button>
    </div>
  </section>
</BaseLayout>
