---
import Button from "../ui/Button.astro";
---

<section class="relative overflow-hidden bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 40px 40px;"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <div class="max-w-3xl">
      <span class="inline-block bg-accent-500/20 text-accent-300 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
        Agencia de Marketing Médico
      </span>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Hacemos crecer tu
        <span class="text-accent-400"> práctica médica</span>
        en el mundo digital
      </h1>
      <p class="text-lg sm:text-xl text-primary-200 leading-relaxed mb-10 max-w-2xl">
        Estrategias de marketing digital diseñadas exclusivamente para profesionales de la salud.
        Más visibilidad, más pacientes, más crecimiento.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <Button href="/#contacto" variant="secondary" size="lg">
          Agenda una consulta gratis
        </Button>
        <Button href="/servicios" variant="outline" size="lg" class="border-white/30 text-white hover:bg-white/10 hover:text-white">
          Ver servicios
        </Button>
      </div>
    </div>
  </div>
</section>
