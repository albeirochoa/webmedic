---
import { benefits } from "../../data/services";
---

<section class="py-20 sm:py-28 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <span class="text-sm font-semibold text-primary-700 uppercase tracking-wider">
        Por qué elegirnos
      </span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mt-3 mb-4">
        Marketing que entiende la salud
      </h2>
      <p class="text-gray-600 leading-relaxed">
        No somos una agencia genérica. Nos especializamos en el sector salud y entendemos sus desafíos únicos.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {
        benefits.map((benefit) => (
          <div class="text-center">
            <div class="text-4xl mb-4">{benefit.icon}</div>
            <h3 class="text-lg font-semibold text-gray-900 mb-2">
              {benefit.title}
            </h3>
            <p class="text-sm text-gray-600 leading-relaxed">
              {benefit.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
