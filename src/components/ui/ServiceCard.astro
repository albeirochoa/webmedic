---
interface Props {
  title: string;
  description: string;
  icon: string;
  features: string[];
}

const { title, description, icon, features } = Astro.props;
---

<article class="bg-white border border-gray-200 rounded-2xl p-8 hover:shadow-lg hover:border-primary-200 transition-all duration-300 group">
  <div class="text-4xl mb-4">{icon}</div>
  <h3 class="text-xl font-bold text-gray-900 mb-3 group-hover:text-primary-700 transition-colors">
    {title}
  </h3>
  <p class="text-gray-600 mb-6 leading-relaxed">
    {description}
  </p>
  <ul class="space-y-2">
    {
      features.map((feature) => (
        <li class="flex items-start gap-2 text-sm text-gray-600">
          <svg class="w-5 h-5 text-accent-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          {feature}
        </li>
      ))
    }
  </ul>
</article>
